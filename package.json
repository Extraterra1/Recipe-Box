    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.15"
